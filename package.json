{
  "name": "pathfinder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace @pathfinder/api\" \"npm run dev --workspace @pathfinder/web\"",
    "dev:web": "npm run dev --workspace @pathfinder/web",
    "dev:api": "npm run dev --workspace @pathfinder/api",
    "build": "npm run build --workspaces --if-present",
    "check": "npm run check --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "deploy:admin-web": "scripts/deploy-admin-web.sh",
    "bootstrap:aws-buckets": "scripts/bootstrap-aws-buckets.sh",
    "deploy:web-hosting": "scripts/deploy-web-hosting.sh",
    "build:api-lambda": "node scripts/build-api-lambda.mjs",
    "build:proof-public-lambda": "node scripts/build-proof-public-lambda.mjs",
    "package:proof-lambdas": "scripts/package-proof-lambdas.sh",
    "test:proof-deploy": "node --test scripts/tests/*.test.mjs",
    "verify:proof-deploy": "node scripts/proof-deploy-preflight.mjs",
    "check:proof-phase2": "node scripts/proof-phase2-readiness.mjs",
    "check:proof-activation-review": "node scripts/proof-readonly-activation-review.mjs",
    "check:proof-window": "node scripts/proof-readonly-window-status.mjs",
    "check:proof-dark-restore": "node scripts/proof-dark-restore-preflight.mjs",
    "check:proof-dns": "node scripts/proof-dns-readiness.mjs",
    "smoke:proof-read-only": "node scripts/smoke-proof-read-only.mjs",
    "qa:proof-synthetic": "node --import tsx/esm scripts/proof-synthetic-lifecycle-qa.ts run",
    "purge:proof-synthetic": "node --import tsx/esm scripts/proof-synthetic-lifecycle-qa.ts purge",
    "qa:proof-boundary": "node --import tsx/esm scripts/proof-customer-boundary-qa.ts",
    "deploy:proof-stack": "scripts/deploy-proof-stack.sh",
    "deploy:proof-web": "scripts/deploy-proof-web.sh",
    "package:api-lambda": "scripts/package-api-lambda.sh",
    "deploy:api-lambda": "scripts/deploy-api-lambda.sh"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "esbuild": "^0.28.1",
    "typescript": "^5.7.3"
  }
}
