# Local API
PATHFINDER_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
PATHFINDER_REQUIRE_AUTH=false
PATHFINDER_ALLOWED_EMAIL_DOMAINS=ltlco.com,vornan.co

# Production web build
PATHFINDER_ADMIN_BUCKET=vornan-pathfinder
PATHFINDER_STATUS_BUCKET=vornan-pathfinder-status
PATHFINDER_ADMIN_CLOUDFRONT_DISTRIBUTION_ID=
PATHFINDER_WEB_STACK_NAME=vornan-pathfinder-web-prod
PATHFINDER_ADMIN_DOMAIN_NAME=pathfinder.vornan.co
PATHFINDER_STATUS_DOMAIN_NAME=status.vornan.co
PATHFINDER_WEB_CERTIFICATE_ARN=
VITE_API_BASE_URL=https://api.pathfinder.vornan.co
VITE_AUTH_REQUIRED=true
VITE_AUTH_ALLOWED_DOMAINS=ltlco.com,vornan.co
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=

# Production API Firebase verification
FIREBASE_PROJECT_ID=
# Prefer AWS Secrets Manager for this in production. Local dev may use ADC instead.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Production API Lambda shell
PATHFINDER_RUNTIME=lambda
PATHFINDER_CUSTOMER_SEED_FILE=/var/task/data/lift-customers.sample.csv
LIFT_CUSTOMER_LIST_URL=https://admin.lifterp.com/ords/lifterp/lift/erp/flush/ondemand/91/CustomerContactLIst/LTL-Customer-List?offset=0
LIFT_CUSTOMER_STATUS_URL=https://ltlco.lifterp.com/ords/lifterp/lift/erp/flush/ondemand/91/CustomerStatusJSON/CustomerStatusJSON?
LIFT_PRODUCT_CATALOG_BASE_URL=https://ltlco.lifterp.com/ords/api/lift/erp
# Certified sandbox-profile submits can use true + live while live-customer profiles remain disabled.
PATHFINDER_ENABLE_LIFT_SUBMIT=false
PATHFINDER_LIFT_TRANSPORT_MODE=dry_run
PATHFINDER_ALLOW_LIVE_CUSTOMER_SUBMIT=false
# OAuth refresh + GET /contacts?me=true only. Keep false until an operator approves a connection test.
PATHFINDER_ENABLE_WRIKE_CONNECTION_TEST=false
# OAuth refresh + one approved task GET + scoped attachment metadata GET. No URLs or file content.
PATHFINDER_ENABLE_WRIKE_DISCOVERY_PREVIEW=false
# Fresh qualification + bounded workbook download into immutable source evidence only. No parsing, job, or Lift action.
PATHFINDER_ENABLE_WRIKE_WORKBOOK_EVIDENCE=false
# Local development only. Production receives an encrypted, versioned S3 bucket from CloudFormation.
PATHFINDER_LOCAL_SOURCE_EVIDENCE_DIR=/tmp/pathfinder-source-evidence
PATHFINDER_PUBLIC_STATUS_BASE_URL=https://status.vornan.co
PATHFINDER_PUBLIC_STATUS_TOKEN_DAYS=30
PATHFINDER_PUBLIC_STATUS_RETURN_LINK=false
PATHFINDER_STATUS_EMAIL_MODE=log
PATHFINDER_STATUS_EMAIL_DEBUG_RETURN_LINK=false
PATHFINDER_EMAIL_FROM="Vornan Updates <notifications@notify.vornan.co>"
PATHFINDER_STATUS_REPLY_TO=support@vornan.co
PATHFINDER_ORDERS_REPLY_TO=orders@vornan.co
PATHFINDER_SYSTEM_REPLY_TO=ops@vornan.co
PATHFINDER_SES_REGION=us-east-1
PATHFINDER_SES_CONFIGURATION_SET=pathfinder-transactional
PATHFINDER_PUBLIC_STATUS_RATE_LIMIT_WINDOW_MS=900000
PATHFINDER_PUBLIC_STATUS_RATE_LIMIT_MAX=5
PATHFINDER_PUBLIC_STATUS_COOLDOWN_MS=60000
PATHFINDER_PUBLIC_STATUS_RATE_LIMIT_PEPPER=
PATHFINDER_PUBLIC_STATUS_EMAIL_MATCH_REQUIRED=true
PATHFINDER_PUBLIC_STATUS_GLOBAL_ALLOWED_DOMAINS=ltlco.com,vornan.co

# API Gateway + Lambda deploy
PATHFINDER_API_STACK_NAME=vornan-pathfinder-api-prod
PATHFINDER_API_ARTIFACT_BUCKET=vornan-pathfinder-artifacts
PATHFINDER_API_ARTIFACT_KEY=
PATHFINDER_API_ENVIRONMENT_NAME=prod
PATHFINDER_API_NAME=vornan-pathfinder-api
PATHFINDER_API_LAMBDA_NAME=vornan-pathfinder-api
PATHFINDER_API_DOMAIN_NAME=api.pathfinder.vornan.co
PATHFINDER_API_CERTIFICATE_ARN=
PATHFINDER_DATA_TABLE_PREFIX=Pathfinder
# Provisioned by the API CloudFormation stack for globally unique Pathfinder Order Numbers.
PATHFINDER_ORDER_IDS_TABLE=Pathfinder-OrderIds-prod
PATHFINDER_SECRET_PREFIX=/vornan/pathfinder/
PATHFINDER_STORAGE_DRIVER=local
PATHFINDER_SECRETS_DRIVER=local
