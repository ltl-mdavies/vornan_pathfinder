# Local API
PATHFINDER_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
PATHFINDER_REQUIRE_AUTH=false
PATHFINDER_ALLOWED_EMAIL_DOMAINS=ltlco.com,vornan.co

# Production web build
VITE_API_BASE_URL=https://api.pathfinder.vornan.co
VITE_AUTH_REQUIRED=true
VITE_AUTH_ALLOWED_DOMAINS=ltlco.com,vornan.co
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=

# Production API Firebase verification
FIREBASE_PROJECT_ID=
# Prefer AWS Secrets Manager for this in production. Local dev may use ADC instead.
FIREBASE_SERVICE_ACCOUNT_JSON=
